PORT=8000
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=8h

# MySQL database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=smart_lpr
DB_CONNECTION_LIMIT=10
DB_QUEUE_LIMIT=0
DB_CONNECT_TIMEOUT_MS=10000
DB_KEEPALIVE_INITIAL_DELAY_MS=0

# AI service
AI_SERVICE_URL=http://localhost:8001
AI_RECOGNIZE_TIMEOUT_MS=5000
AI_RECOGNIZE_RETRIES=1

# Upload
MAX_FILE_SIZE=10485760

# Public base URL (used by CSV/export/media links)
PUBLIC_BASE_URL=http://localhost:8000

# Storage: local | cos
STORAGE_DRIVER=local

# Tencent COS (required when STORAGE_DRIVER=cos)
COS_BUCKET=
COS_REGION=
COS_SECRET_ID=
COS_SECRET_KEY=
# Optional: public bucket/CDN base URL, e.g. https://your-bucket.cos.ap-shanghai.myqcloud.com
COS_PUBLIC_BASE_URL=
# Signed URL TTL for private bucket preview/download
COS_SIGNED_URL_EXPIRES_SECONDS=600

# Alarm clip persistence
ALARM_CLIP_ENABLED=true
ALARM_CLIP_DURATION_SEC=12
ALARM_CLIP_TIMEOUT_MS=45000
ALARM_CLIP_FFMPEG_BIN=ffmpeg
